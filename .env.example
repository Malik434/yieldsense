# ─── Processor runtime environment ───────────────────────────────────────────
# Injected into the Acurast Cargo job via _STD_.environment (encrypted on-chain).
# For local dev, copy to .env and fill in values.

# The user's wallet address — baked into the bundle at deploy time by /api/deploy.
# In production this is injected via esbuild define, not this file.
USER_ADDRESS=0x0000000000000000000000000000000000000000

# Deployed YieldSenseKeeper contract address
KEEPER_ADDRESS=0x0000000000000000000000000000000000000000

# RPC endpoint for submitting executeTrade transactions
RPC_URL=https://sepolia.base.org

# RPC endpoint for reading on-chain price data (can be mainnet for live prices)
DATA_RPC_URL=https://sepolia.base.org

# Chain ID (84532 = Base Sepolia, 8453 = Base Mainnet)
# Must match CHAIN_ID in the frontend/.env
CHAIN_ID=84532

# Frontend URL for fetching signed strategy params from /api/strategy
FRONTEND_URL=https://your-deployment.netlify.app

# Telemetry endpoint (defaults to FRONTEND_URL/api/telemetry if not set)
# TELEMETRY_URL=https://your-deployment.netlify.app/api/telemetry

# Shared secret for telemetry API authentication.
# Must match PROCESSOR_SHARED_SECRET in the frontend/.env.
# Generate: openssl rand -hex 32
PROCESSOR_SHARED_SECRET=change_me_generate_with_openssl_rand_hex_32

# Uniswap/Aerodrome V3 pool address for price data
# Default: WETH/USDC 0.05% on Base mainnet
UNISWAP_POOL_ADDRESS=0xb2cc224c1c9fee385f8ad6a55b4d94e92359dc59

# Decimal correction factor for sqrtPriceX96 → USD price.
# WETH/USDC (18 dec / 6 dec): 10^(18-6) = 1e12
# WBTC/USDC (8 dec / 6 dec):  10^(8-6)  = 1e2
POOL_DECIMAL_FACTOR=1e12

# ─── Local dev / Hardhat only ─────────────────────────────────────────────────
# Private key of the deployer / owner — used in scripts and local fallback signing.
# NEVER commit a key with real funds. Use a dedicated test wallet.
ACURAST_WORKER_KEY=0xdeadbeef...

# ─── Deployment scripts ───────────────────────────────────────────────────────
# Optional: override which processor address to attest in scripts/attestProcessor.cjs
# PROCESSOR_ADDRESS=0x...
# Optional: frontend URL for auto-discovery of hw_address_report
# FRONTEND_URL=https://yieldsense.huzaifamalik.tech

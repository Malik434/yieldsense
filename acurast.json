{
  "projects": {
    "YieldSense": {
      "projectName": "YieldSense",
      "fileUrl": "dist/index.bundle.cjs",
      "network": "mainnet",
      "onlyAttestedDevices": true,
      "assignmentStrategy": {
        "type": "Single"
      },
      "execution": {
        "type": "interval",
        "intervalInMs": 3600000,
        "numberOfExecutions": 5
      },
      "maxAllowedStartDelayInMs": 60000,
      "usageLimit": {
        "maxMemory": 256000000,
        "maxNetworkRequests": 30,
        "maxStorage": 1000000
      },
      "numberOfReplicas": 1,
      "requiredModules": [],
      "minProcessorReputation": 0,
      "maxCostPerExecution": 3300158999,
      "includeEnvironmentVariables": [
        "DATA_RPC_URL",
        "GAUGE_ADDRESS",
        "ASSET_ADDRESS",
        "AUTOCOMPOUNDER_ADDRESS",
        "USER_ADDRESS",
        "GRID_CONFIG_JSON",
        "HARVEST_MIN_ASSET_OUT",
        "TELEMETRY_URL",
        "FORCE_TEST_HARVEST",
        "YIELD_FALLBACK_MODE",
        "YIELD_CHAIN_ID",
        "POOL_FEE_BPS",
        "EST_GAS_UNITS"
      ],
      "processorWhitelist": []
    }
  }
}
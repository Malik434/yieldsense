{
  "projects": {
    "YieldSense": {
      "projectName": "YieldSense",
      "fileUrl": "dist/index.bundle.cjs",
      "network": "mainnet",
      "onlyAttestedDevices": true,
      "assignmentStrategy": {
        "type": "Single"
      },
      "execution": {
        "type": "interval",
        "intervalInMs": 3600000,
        "numberOfExecutions": 5
      },
      "maxAllowedStartDelayInMs": 60000,
      "usageLimit": {
        "maxMemory": 256000000,
        "maxNetworkRequests": 30,
        "maxStorage": 1000000
      },
      "numberOfReplicas": 1,
      "requiredModules": [],
      "minProcessorReputation": 0,
      "maxCostPerExecution": 10000000000,
      "includeEnvironmentVariables": [
        "RPC_URL",
        "KEEPER_ADDRESS",
        "DATA_RPC_URL",
        "POOL_ADDRESS",
        "FORCE_TEST_HARVEST",
        "PROCESSOR_SHARED_SECRET",
        "USER_ADDRESS"
      ],
      "processorWhitelist": []
    }
  }
}